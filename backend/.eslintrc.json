{
  "env": {
    "node": true,
    "es2021": true
  },
  "parserOptions": {
    "ecmaVersion": 2021
  },
  "rules": {
    "no-redeclare": "error",
    "no-undef": "error",
    "no-unused-vars": "warn",
    "no-dupe-keys": "error",
    "no-duplicate-case": "error",
    "no-unreachable": "warn"
  },
  "ignorePatterns": ["node_modules/"]
}
